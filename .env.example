DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=marketplace_assistant
POSTGRES_USER=marketplace_assistant
POSTGRES_PASSWORD=marketplace_assistant
POSTGRES_HOST=db
POSTGRES_PORT=5432

OPENAI_API_KEY=

# LLM_PROVIDER=openai uses OPENAI_API_KEY above.
# LLM_PROVIDER=ollama talks to a local Ollama server instead (no key needed).
LLM_PROVIDER=openai
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
